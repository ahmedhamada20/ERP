APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ── Session hardening ──────────────────────────────────────────
# DEV (local HTTP, Laragon):  SESSION_SECURE_COOKIE=false
# PROD (behind HTTPS):        SESSION_SECURE_COOKIE=true
#
# All other values below are the recommended secure defaults — keep them as-is.
# SESSION_ENCRYPT=true encrypts session payloads in the DB (default in config).
# SESSION_HTTP_ONLY=true blocks JS access to the cookie (CSRF/XSS hardening).
# SESSION_SAME_SITE=lax mitigates CSRF on cross-site requests.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Daily Backup (custom backup:run + backup:clean commands) ─
# MYSQLDUMP_PATH:    إذا mysqldump مش في الـ PATH العام، حدد المسار الكامل
#                    (Laragon: C:\laragon\bin\mysql\mysql-x.x.x-winx64\bin\mysqldump.exe)
# BACKUP_NOTIFY_EMAIL: إيميل يستقبل إشعار عند فشل الـ backup
# BACKUP_KEEP_*:     سياسة الاحتفاظ (يومي/أسبوعي/شهري)
MYSQLDUMP_PATH=mysqldump
BACKUP_NOTIFY_EMAIL=
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
